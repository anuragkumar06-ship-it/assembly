pageType: content
background:
  type: solid
  color: "$primary"
elements:
  # Section number
  - elementId: sec-num
    elementType: text
    bounds: [80, 40, 120, 24]
    content:
      fontSize: 12
      fontFamily: "QuattrocentoSans"
      color: "#FFFFFF30"
      wrap: false
      text: |
        <p>02 / 10</p>

  # Section eyebrow
  - elementId: eyebrow
    elementType: text
    bounds: [80, 68, 300, 24]
    content:
      style: "$eyebrowLight"
      wrap: false
      text: |
        <p>THE SHARK TANK MOMENT</p>

  # Section heading
  - elementId: heading
    elementType: text
    bounds: [80, 96, 600, 120]
    content:
      style: "$sectionHeadingLight"
      text: |
        <p>Five Exits,<br><em style="color:#F3EDE580;">Five Different Lenses</em></p>

  # Primary quote box
  - elementId: quote-box
    elementType: shape
    bounds: [80, 220, 1120, 100]
    shapeName: roundRect
    adjustments: [4000]
    fill:
      type: solid
      color: "#FFFFFF0A"
    border:
      style: solid
      width: 1
      color: "#FFFFFF14"

  - elementId: quote-accent
    elementType: shape
    bounds: [80, 220, 4, 100]
    shapeName: rect
    fill:
      type: solid
      color: "$secondary"

  - elementId: quote-text
    elementType: text
    bounds: [108, 228, 1060, 68]
    content:
      fontSize: 20
      fontFamily: "SortsMillGoudy"
      color: "$background"
      lineHeight: 1.4
      text: |
        <p><em>"There are less lifestyle elements in your design right now and too much minimalist vibe... you need a brand guy who can help you. I can't make up my mind. Unfortunately, I'm out."</em></p>

  - elementId: quote-attr
    elementType: text
    bounds: [108, 296, 1060, 20]
    content:
      fontSize: 12
      fontFamily: "QuattrocentoSans"
      color: "#F3EDE560"
      text: |
        <p>— Aman Gupta, Co-founder & CMO, boAt · Primary objection of the episode</p>

