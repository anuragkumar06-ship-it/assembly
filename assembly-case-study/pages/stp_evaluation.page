      fontSize: 16
      fontFamily: "QuattrocentoSans"
      color: "$text"
      lineHeight: 1.3
      text: |
        <p><strong>Right segment, wrong brand voice</strong></p>

  - elementId: e2-body
    elementType: text
    bounds: [486, 306, 330, 74]
    content:
      fontSize: 13
      fontFamily: "QuattrocentoSans"
      color: "$textLight"
      lineHeight: 1.5
      text: |
        <p>The targeting decision was valid. The failure was deploying a minimalist brand voice into a segment that responds to aspiration.</p>

  - elementId: e2-verdict-bg
    elementType: shape
    bounds: [486, 382, 120, 28]
    shapeName: roundRect
    adjustments: [8000]
