pageType: content
background:
  type: solid
  color: "$backgroundDark"
elements:
  # Section number
  - elementId: sec-num
    elementType: text
    bounds: [80, 30, 120, 24]
    content:
      fontSize: 12
      fontFamily: "QuattrocentoSans"
      color: "#0F3D3580"
      wrap: false
      text: |
        <p>07 / 10</p>

  # Section eyebrow
  - elementId: eyebrow
    elementType: text
    bounds: [80, 58, 300, 24]
    content:
      style: "$eyebrow"
      color: "$primary"
      wrap: false
      text: |
        <p>CRITICAL STP EVALUATION</p>

  # Section heading
  - elementId: heading
    elementType: text
    bounds: [80, 86, 600, 120]
    content:
      style: "$sectionHeading"
      text: |
        <p>Where the Strategy<br><em style="color:#A56A3A;">Broke Down</em></p>

  # Evaluation Grid — 3 columns x 2 rows
  # Card 1
  - elementId: e1-bg
    elementType: shape
    bounds: [80, 216, 370, 218]
    shapeName: roundRect
    adjustments: [4000]
    fill:
      type: solid
      color: "#FFFFFF"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: e1-num
    elementType: text
    bounds: [100, 228, 60, 20]
    content:
      fontSize: 11
      fontFamily: "QuattrocentoSans"
      color: "#2E2E2E60"
      wrap: false
      text: |
        <p>01</p>

  - elementId: e1-title
    elementType: text
    bounds: [100, 252, 330, 48]
    content:
      fontSize: 16
      fontFamily: "QuattrocentoSans"
      color: "$text"
      lineHeight: 1.3
      text: |
        <p><strong>Psychographically shallow segmentation</strong></p>

  - elementId: e1-body
    elementType: text
    bounds: [100, 306, 330, 74]
    content:
      fontSize: 13
      fontFamily: "QuattrocentoSans"
      color: "$textLight"
      lineHeight: 1.5
      text: |
        <p>HENRY label correct but psychographic depth lacking. "Less is more" attracts only the design-minimalist sub-segment.</p>

  - elementId: e1-verdict-bg
    elementType: shape
    bounds: [100, 382, 110, 28]
    shapeName: roundRect
    adjustments: [8000]
    fill:
      type: solid
      color: "#C0392B12"
    border:
      style: solid
      width: 1
      color: "#C0392B20"

  - elementId: e1-verdict
    elementType: text
    bounds: [100, 382, 110, 28]
    content:
      fontSize: 10
      fontFamily: "QuattrocentoSans"
      color: "$red"
      letterSpacing: 1
      align: [center, middle]
      wrap: false
      text: |
        <p>CRITICAL GAP</p>

  # Card 2
  - elementId: e2-bg
    elementType: shape
    bounds: [466, 216, 370, 218]
    shapeName: roundRect
    adjustments: [4000]
    fill:
      type: solid
      color: "#FFFFFF"
    border:
      style: solid
      width: 1
      color: "$border"

  - elementId: e2-num
