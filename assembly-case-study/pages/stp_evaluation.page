    content:
      fontSize: 13
      fontFamily: "QuattrocentoSans"
      color: "$textLight"
      lineHeight: 1.5
      text: |
        <p>"50% design, 50% functionality at the right price" is a feature description. Assembly owned no word in the consumer's mind.</p>

  - elementId: e3-verdict-bg
