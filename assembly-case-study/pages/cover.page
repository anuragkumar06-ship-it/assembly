pageType: cover
background:
  type: solid
  color: "$primaryDark"
elements:
  # LEFT COLUMN
  - elementId: eyebrow
    elementType: text
    bounds: [80, 100, 500, 24]
    content:
      style: "$eyebrowLight"
      color: "#7FA3A0"
      wrap: false
      text: |
        <p>IIM INDIVIDUAL ASSIGNMENT · MARKETING STRATEGY</p>

  - elementId: main-title
    elementType: text
    bounds: [80, 144, 540, 250]
    content:
      style: "$coverTitle"
      fontSize: 64
      lineHeight: 1.05
      text: |
        <p>Assembly</p>
        <p style="margin-top:8px"><em style="font-style:italic; color:#F3EDE580;">Shark Tank</em></p>
        <p style="margin-top:8px">Case Study</p>

  - elementId: subtitle
    elementType: text
    bounds: [80, 404, 500, 100]
    content:
      style: "$bodyLight"
      fontSize: 18
      lineHeight: 1.6
      text: |
        <p>A critical analysis of Assembly's STP strategy, Shark Tank India Season 3 appearance, and a three-horizon growth recommendation.</p>

  # Tags - wrapped in shapes for border
  - elementId: tag1-bg
    elementType: shape
    bounds: [80, 520, 140, 34]
    shapeName: roundRect
    adjustments: [2000]
    fill:
      type: solid
      color: "#0a2921"
    border:
      style: solid
      width: 1
      color: "#6E8F8B4D"

  - elementId: tag1
    elementType: text
    bounds: [80, 520, 140, 34]
    content:
      fontSize: 12
      fontFamily: "QuattrocentoSans"
      color: "$secondaryLight"
      letterSpacing: 1.5
      align: [center, middle]
      wrap: false
      text: |
        <p>SEGMENTATION</p>

  - elementId: tag2-bg
    elementType: shape
    bounds: [232, 520, 130, 34]
    shapeName: roundRect
