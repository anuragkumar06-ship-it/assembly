pageType: final
background:
  type: solid
  color: "$primaryDark"
elements:
  # Center content
  - elementId: headline
    elementType: text
    bounds: [190, 160, 900, 140]
    content:
      fontSize: 52
      fontFamily: "SortsMillGoudy"
      color: "$background"
      lineHeight: 1.05
      align: [center, top]
      text: |
        <p>The Brand Gap<br><em style="color:#F3EDE540;">is the Opportunity</em></p>

  - elementId: sub-text
    elementType: text
