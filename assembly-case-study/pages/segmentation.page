pageType: content
background:
  type: solid
  color: "$offwhite"
elements:
  # Section number
  - elementId: sec-num
    elementType: text
    bounds: [80, 50, 120, 24]
    content:
      fontSize: 12
      fontFamily: "QuattrocentoSans"
      color: "#0F3D354D"
      wrap: false
      text: |
        <p>04 / 10</p>

  # Section eyebrow
  - elementId: eyebrow
    elementType: text
    bounds: [80, 78, 200, 24]
